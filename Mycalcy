# ================= KEYBOARD =================
def key_input(event):
    key = event.char

    if key in "0123456789+-*/.%":
        click(key)
    elif event.keysym == "Return":
        calculate()
    elif event.keysym == "BackSpace":
        backspace()
    elif event.keysym == "Escape":
        clear()

#root.bind("<Key>", key_input)

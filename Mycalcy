# ================= DATA =================
history = []
memory = 0

# ================= FUNCTIONS =================
def click(value):
    entry.insert(tk.END, value)

def clear():
    entry.delete(0, tk.END)

def backspace():
    if entry.get():
        entry.delete(len(entry.get())-1)

def calculate():
    try:
        expression = entry.get()
        result = eval(expression, {"__builtins__": None}, {
            "sin": math.sin,
            "cos": math.cos,
            "tan": math.tan,
            "sqrt": math.sqrt,
            "log": math.log10,
            "ln": math.log,
            "pi": math.pi,
            "e": math.e
        })

        entry.delete(0, tk.END)
        entry.insert(tk.END, result)

        history.append(f"{expression} = {result}")

    except:
        entry.delete(0, tk.END)
        entry.insert(tk.END, "Error")

# ================= MEMORY =================
def memory_add():
    global memory
    try:
        memory += float(entry.get())
    except:
        pass

def memory_sub():
    global memory
    try:
        memory -= float(entry.get())
    except:
        pass

def memory_recall():
    entry.delete(0, tk.END)
    entry.insert(tk.END, memory)

def memory_clear():
    global memory
    memory = 0


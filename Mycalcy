    win = tk.Toplevel(root)
    win.title("History")
    win.geometry("300x300")

    for item in history:
        tk.Label(win, text=item, anchor="w").pack()

#====================Statistics=================
def get_data():
    try:
        data = entry.get().split(",")
        return [float(i) for i in data]
    except:
        return []

def calc_mean():
    data = get_data()
    if data:
        result = statistics.mean(data)
        entry.delete(0, tk.END)
        entry.insert(tk.END, f"Mean={round(result,2)}")
    else:
        entry.insert(tk.END, "Error")


def calc_median():
    data = get_data()
    if data:
        result = statistics.median(data)
        entry.delete(0, tk.END)
        entry.insert(tk.END, f"Median={result}")
    else:
        entry.insert(tk.END, "Error")


def calc_mode():
    data = get_data()
    try:
        result = statistics.mode(data)
        entry.delete(0, tk.END)
        entry.insert(tk.END, f"Mode={result}")
    except:
        entry.delete(0, tk.END)
        entry.insert(tk.END, "No Mode")


def calc_std():
    data = get_data()
    if data:
        result = statistics.stdev(data)
        entry.delete(0, tk.END)
        entry.insert(tk.END, f"Std={round(result,2)}")
    else:
        entry.insert(tk.END, "Error")


def calc_variance():
    data = get_data()
    if data:
        result = statistics.variance(data)
        entry.delete(0, tk.END)
        entry.insert(tk.END, f"Var={round(result,2)}")
    else:
        entry.insert(tk.END, "Error")

def calc_correlation():
    try:
        text = entry.get()

        x_part, y_part = text.split(";")

        x_vals = [float(i) for i in x_part.split(",")]
        y_vals = [float(i) for i in y_part.split(",")]

        n = len(x_vals)

        mean_x = sum(x_vals) / n
        mean_y = sum(y_vals) / n

        num = sum((x_vals[i] - mean_x)*(y_vals[i] - mean_y) for i in range(n))

        den_x = sum((x_vals[i] - mean_x)**2 for i in range(n))
        den_y = sum((y_vals[i] - mean_y)**2 for i in range(n))

        correlation = num / ((den_x * den_y) ** 0.5)

        entry.delete(0, tk.END)
        entry.insert(tk.END, f"Corr={round(correlation,2)}")

    except:
        entry.delete(0, tk.END)
        entry.insert(tk.END, "Error")

# ================= GRAPH =================
def plot_graph():
    try:
        expr = entry.get()

        # Allow multiple expressions (comma separated)
        expressions = expr.split(",")

        x = np.linspace(-10, 10, 200)
        plt.figure()

        for exp in expressions:
            exp = exp.strip()
        
            y = eval(exp, {"__builtins__": None}, {
                "x": x,
                "sin": np.sin,
                "cos": np.cos,
                "tan": np.tan
            })
            plt.plot(x, y, label=exp)

        plt.title("Graph")
        plt.xlabel("X axis")
        plt.ylabel("Y axis")
        #plt.axhline(0)   # X-axis
        #plt.axvline(0)   # Y-axis
        plt.legend()
        plt.grid()
        plt.show()

    except:
        entry.delete(0, tk.END)
        entry.insert(tk.END, "Graph Error")

